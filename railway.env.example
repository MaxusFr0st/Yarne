# Copy these into Railway service variables (do not commit real secrets).
# Backend service — Root Directory: YarneBack/YarneAPIBack/YarneAPIBack

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080

# Link Postgres plugin on the API service → adds DATABASE_URL automatically.
# Or paste the postgres:// URL from Railway Postgres → Connect.
# DATABASE_URL=postgresql://user:pass@host:port/railway

Jwt__Issuer=YarneAPI
Jwt__Audience=YarneApp
# REQUIRED — generate a fresh secret (e.g. `openssl rand -base64 48`).
# NEVER use the value from appsettings.json; ProductionStartupValidator blocks the old dev key on startup.
Jwt__Secret=<generate-fresh-value-never-copy-from-appsettings>
Jwt__AdminExpiration=02:00:00
Jwt__CustomerExpiration=00:45:00

Cors__AllowedOrigins__0=https://<your-frontend>.up.railway.app
Cors__AllowedOrigins__1=https://yarne.acc
Cors__AllowedOrigins__2=https://www.yarne.acc

# Railway health probes use localhost; public traffic uses *.up.railway.app (or your custom domain).
# AllowedHosts=*.up.railway.app;localhost;127.0.0.1;yourdomain.com

# First deploy: seeds catalog + admin when DB is empty (idempotent).
# APP_SEED_ADMIN_PASSWORD=Admin123!
# Admin login: max@gmail.com / maxadmin

# Order confirmation email (backend API service)
# Gmail: use an App Password (2FA required). SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=<gmail-app-password>
# EMAIL_FROM=your@gmail.com

# Frontend service — Root Directory: YarneFront
# VITE_API_URL=https://<your-backend>.up.railway.app
# OAuth (optional — omit to hide social login buttons)
# VITE_GOOGLE_CLIENT_ID=<google-oauth-web-client-id>
# VITE_APPLE_CLIENT_ID=<apple-services-id>
# VITE_APPLE_REDIRECT_URI=https://<your-frontend>.up.railway.app
#
# Google OAuth — fix Error 400 origin_mismatch:
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Under "Authorized JavaScript origins" add EVERY URL users open in the browser (exact, no path, no trailing slash):
#   https://yarne.acc
#   https://www.yarne.acc
#   https://<your-frontend>.up.railway.app
#   http://localhost:5173
# Changes can take a few minutes to apply. VITE_GOOGLE_CLIENT_ID must match this same client.

# Backend OAuth (required only when social login is enabled)
# OAuth__Google__ClientId=<same-as-VITE_GOOGLE_CLIENT_ID>
# OAuth__Apple__ServiceId=<same-as-VITE_APPLE_CLIENT_ID>
