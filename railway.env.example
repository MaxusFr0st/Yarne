# Copy these into Railway service variables (do not commit real secrets).
# Backend service — Root Directory: YarneBack/YarneAPIBack/YarneAPIBack

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080

# Link Postgres plugin on the API service → adds DATABASE_URL automatically.
# Or paste the postgres:// URL from Railway Postgres → Connect.
# DATABASE_URL=postgresql://user:pass@host:port/railway

Jwt__Issuer=YarneAPI
Jwt__Audience=YarneApp
Jwt__Secret=<at-least-32-characters>
Jwt__AdminExpiration=02:00:00
Jwt__CustomerExpiration=00:45:00

Cors__AllowedOrigins__0=https://<your-frontend>.up.railway.app

# Railway health probes use localhost; public traffic uses *.up.railway.app (or your custom domain).
# AllowedHosts=*.up.railway.app;localhost;127.0.0.1;yourdomain.com

# First deploy: seeds catalog + admin when DB is empty (idempotent).
# APP_SEED_ADMIN_PASSWORD=Admin123!
# Admin login: max@gmail.com / maxadmin

# JWT — set ONLY Jwt__Secret on the API service (delete legacy JWT_SECRET if present).
# Jwt__Secret=<generate-a-64-byte-base64-secret>

# Frontend service — Root Directory: YarneFront
# VITE_API_URL=https://<your-backend>.up.railway.app
